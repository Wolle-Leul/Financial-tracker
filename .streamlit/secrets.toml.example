# Streamlit Cloud secrets template
#
# Copy values into your real Streamlit secrets configuration.
# Do not commit real credentials to git.

# Database connection string (Postgres/Supabase).
# Example (Postgres):
# db_url = "postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME"
db_url = "postgresql+psycopg://user:password@localhost:5432/finance_tracker"

# Authentication secrets (current app uses plaintext password gate).
password = "change-me"

# When you migrate auth to hashed passwords, set this too.
# password_hash = "$2b$12$..."

# Optional business rules
holiday_country = "Poland"
salary_day_of_month = 10
target_ratio = 0.45

